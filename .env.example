# Ollama (лёгкая модель для слабого железа)
OLLAMA_MODEL=llama3.2:1b

# Backend
CHUNK_SIZE=400
CHUNK_OVERLAP=30
TOP_K=5
MAX_TOP_K=100
LLM_TOP_K=6
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=8
TORCH_NUM_THREADS=2

# Старт
INDEX_ON_STARTUP=false
WATCH_DOCUMENTS=true
PREWARM_EMBEDDINGS=true

# LLM
OLLAMA_TIMEOUT=180
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_THREAD=4
LLM_NUM_PREDICT=128
LLM_MAX_CONTEXT_CHARS=2500

# Frontend (внутри Docker-сети)
API_URL=http://backend:8000
STATS_CACHE_TTL=60
ASK_TIMEOUT=180
