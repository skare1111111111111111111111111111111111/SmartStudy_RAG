# Ollama (лёгкая модель для слабого железа)
OLLAMA_MODEL=llama3

# Backend
CHUNK_SIZE=400
CHUNK_OVERLAP=30
TOP_K=15
MAX_TOP_K=100
LLM_TOP_K=10
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=8
TORCH_NUM_THREADS=2

# Старт
INDEX_ON_STARTUP=false
WATCH_DOCUMENTS=true
PREWARM_EMBEDDINGS=true

# LLM
OLLAMA_TIMEOUT=180
OLLAMA_NUM_CTX=3072
OLLAMA_NUM_THREAD=4
LLM_TEMPERATURE=0.1
LLM_NUM_PREDICT=320
LLM_MAX_CONTEXT_CHARS=4500

# Frontend (внутри Docker-сети)
API_URL=http://backend:8000
STATS_CACHE_TTL=60
ASK_TIMEOUT=180
